{
  "permissions": {
    "allow": [
      "mcp__fastedgy-docs__searchMkDoc",
      "mcp__fastedgy-docs__fetchMkDoc",
      "Bash(uv run ruff format:*)",
      "Bash(uv run ruff check:*)"
    ]
  },
  "enableAllProjectMcpServers": true,
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          { "type": "command", "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/py-format.sh\"" }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          { "type": "command", "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/py-gate.sh\"", "timeout": 120 }
        ]
      }
    ]
  }
}
